! Ресурсы XTerm
!
! Не забудьте выполнить `xrdb < .Xresources` после изменения чего-либо.
!
! Tavis Ormandy <taviso@gmail.com>
! Копировать выделенное сразу в системный буфер обмена
XTerm*selectToClipboard: true

! Установить шрифт интерфейса по умолчанию (меню, панель инструментов и т.д.)
XTerm*XftFont:                  Inter:size=10:antialias=true:style=Regular

! Цвет компонентов интерфейса
XTerm*.SimpleMenu.background:   #ffffff
XTerm*.SimpleMenu.foreground:   #000000

! Ослабить 3D-эффект Xaw3D.
XTerm*shapeStyle:               Rectangle
XTerm*beNiceToColormap:         false
XTerm*relief:                   None
XTerm*highlightThickness:       0

! Не прокручивать автоматически вниз при выводе,
! но прокручивать при нажатии клавиши.
XTerm*scrollTtyOutput:          false
XTerm*scrollKey:                true
XTerm*scrollBar:                false
XTerm*eightBitInput:            false
XTerm*cursorBlink:              true

! Не разрешать операции мышью — их можно включить через меню View во время работы.
! Причина в том, что это ломает копирование/вставку, если приложение запрашивает события мыши,
! потому что событие получает приложение, а не XTerm.
XTerm*allowMouseOps:            false

! По умолчанию не изменять заголовок окна, это можно снова включить из меню.
XTerm*allowTitleOps:            false
XTerm*allowFontOps:             false

! Настройка курсора мыши, предпочитаю простой вариант.
XTerm*pointerColor:             white
XTerm*pointerColorBackground:   black
XTerm*pointerShape:             left_ptr

! Выделять только текст, а не пустое пространство вокруг него.
XTerm*highlightSelection:       true

! Расстояние между краем окна и символами.
XTerm*vt100.internalBorder:     6

! Граница вокруг элементов.
XTerm*.BorderColor:             #ffffff
XTerm*vt100.BorderColor:        #d0d0d0
XTerm*BorderWidth:              3

! Названия меню — мне не нравятся стандартные многословные названия.
XTerm*.mainMenu.label:          File
XTerm*.vtMenu.label:            Options
XTerm*.fontMenu.label:          View

! Можно переименовать пункты меню вот так.
! Не знаю, почему строка меню называется "toolbar",
! вероятно, исторические причины.
XTerm*.mainMenu.toolbar.label:  Menubar

! Настройка внешнего вида активного пункта меню
XTerm*.SimpleMenu.*.shadowWidth: 3
XTerm*.SimpleMenu.*.topShadowPixel: SkyBlue
XTerm*.SimpleMenu.*.bottomShadowPixel: LightSkyBlue

! Попытка скрыть бесполезный заголовок,
! отображаемый в верхней части меню — я и так знаю,
! какое меню открыл, потому что только что на него нажал.
XTerm*.*.menuLabel.vertSpace:   0
XTerm*.*.menuLabel.foreground:  #ffffff
XTerm*.*.menuLabel.XftFont:     Courier:size=0

! Отступы вокруг пунктов меню.
XTerm*.SimpleMenu.*.topMargin:  0
XTerm*.SimpleMenu.*.bottomMargin: 0
XTerm*.SimpleMenu.*.leftMargin: 32
XTerm*.SimpleMenu.*.rightMargin: 64
! Высота каждого пункта меню — по умолчанию вычисляется из размера шрифта.
! XTerm*.SimpleMenu.*.rowHeight: 16

! Отступ вокруг галочки (флажка) в меню.
XTerm*.SimpleMenu.*.leftWhitespace: 16
!XTerm*.SimpleMenu.*.rightWhitespace: 8

! Уменьшить вертикальные отступы вокруг панели меню,
! все элементы имеют форму.
XTerm*Form.menubar.vSpace:      0
XTerm*Form.menubar.vertDistance: 0
!XTerm*Form.menubar.foreground: #000000
!XTerm*Form.menubar.background: #ffffff
!XTerm*Form.menubar.Thickness:  0

! Шрифты
XTerm*vt100.faceName:           xft:Consolas:size=12:antialias=true:style=Regular
XTerm*vt100.boldFont:           xft:Consolas:size=12:antialias=true:style=Bold

! Размер окна и заголовок
XTerm*vt100.geometry:           80x24
XTerm*title:                    Terminal
XTerm*iconHint:                 /home/taviso/.icons/computer_x11.xpm

! Цвета терминала
XTerm*vt100.background:     #121212
XTerm*vt100.foreground:     #ffffff
XTerm*cursorColor:          #ffffff

! Жирный текст отображать ярко-белым.
XTerm*veryBoldColors:       4
XTerm*colorBDMode:          true
XTerm*colorBD:              #ffffff
XTerm*colorRV:              #ffffff

! Я вижу тонкую линию между псевдографическими символами — это исправляет проблему.
XTerm*forceBoxChars:        true
XTerm*vt100.scaleHeight:    1.04

! Этот (или похожий id) необходим для поддержки Sixel.
XTerm*decTerminalID:        vt382

! Цветовая схема
! 0-7:  Чёрный, Красный, Зелёный, Жёлтый, Синий, Фиолетовый, Голубой, Белый
! 8-15: Яркий чёрный, Яркий красный, ...
XTerm*color0:               #212121
XTerm*color8:               #7f7f7f
XTerm*color1:               #A00000
XTerm*color9:               #FF0000
XTerm*color2:               #00A000
XTerm*color10:              #00FF00
XTerm*color3:               #A0A000
XTerm*color11:              #FFFF00
XTerm*color4:               #0000A0
XTerm*color12:              #5C5CFF
XTerm*color5:               #A000A0
XTerm*color13:              #FF00FF
XTerm*color6:               #00A0A0
XTerm*color14:              #00FFFF
XTerm*color7:               #C0C0C0
XTerm*color15:              #ffffff

! Трансляции XTerm, т.е. переназначение клавиатуры.
!
! Примечания:
!   ~       означает, что модификатор НЕ должен быть нажат.
!   !       означает, что перечисленные модификаторы должны быть нажаты,
!               и никакие другие модификаторы не должны быть нажаты.
!   None    означает, что никакие модификаторы не должны быть нажаты.
!   :       указывает Intrinsics применить стандартные модификаторы события.
!   ^       сокращение для модификатора Control.
!   $       сокращение для Meta
!
! Пример:
!   Без модификаторов:                     None <event> detail
!   Любые модификаторы:                         <event> detail
!   Только указанные модификаторы:      ! mod1 mod2 <event> detail
!   Эти модификаторы и любые другие:    mod1 mod2 <event> detail

! Ниже:
!
! - У меня есть старые приложения, использующие Alt-F4,
!       но иногда это неудобно нажимать,
!       поэтому Ctrl-Shift-F4 делает то же самое.
! - Ctrl + колесо мыши можно использовать
!       для увеличения и уменьшения размера шрифта.
! - Ctrl-I совершенно бесполезен,
!       потому что приложения не могут отличить его от Tab.
!       Здесь можно переназначить его на другую,
!       более сложную комбинацию клавиш.
!       Я использую его для курсива в WordPerfect.

XTerm*vt100.translations:   #override           \n\
    Ctrl Shift <Key>F4:     string("\033[1;3S") \n\
  ! Ctrl <Btn4Up>:          larger-vt-font()    \n\
  ! Ctrl <Btn5Up>:          smaller-vt-font()   \n\
    ^<Key>I:                string("\014")      \n\
